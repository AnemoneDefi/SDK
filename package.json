{
  "name": "@anemone/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Anemone Interest Rate Swap Protocol on Solana",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
