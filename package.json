{
  "name": "@anemone/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Anemone Interest Rate Swap Protocol on Solana",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "vitest run --config e2e/vitest.e2e.config.ts"
  },
  "keywords": [
    "solana",
    "defi",
    "interest-rate-swap",
    "anchor"
  ],
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.98.0",
    "bn.js": "^5.2.1"
  },
  "devDependencies": {
    "@kamino-finance/klend-sdk": "^7.3.22",
    "@types/bn.js": "^5.1.6",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
